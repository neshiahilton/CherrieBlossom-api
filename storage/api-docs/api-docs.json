                            }
                        }
                    },
                    "400": {
                        "description": "Invalid data supplied"
                    },
                    "404": {
                        "description": "Bouquet not found"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Bouquet"
                ],
                "summary": "Delete a bouquet",
                "operationId": "deleteBouquet",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of bouquet to be deleted",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
